# Python cache and build artifacts
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
build/
dist/
*.egg-info/

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE and local tooling (这里是重点！)
.idea/                # 完整忽略整个.idea目录，包括里面的xml文件
.jbeval/
.vscode/

# LangGraph runtime files (这里是重点！)
.langgraph_api/       # 必须加/，忽略整个目录
*.pckl                # 忽略所有.pckl文件
*.pkl                 # 忽略所有.pkl文件

# Logs
logs/
*.log
*.log.*

# Local config and secrets
.env
.env.*
*.local

# Large model files and ML artifacts
rag_qa/models/
rag_qa/core/bert_results/
rag_qa/nlp_bert_document-segmentation_chinese-base/
models/*
!models/.gitkeep
!models/README.md
checkpoints/
outputs/
runs/
wandb/
mlruns/
*.pt
*.pth
*.bin
*.ckpt
*.safetensors
*.onnx
*.tflite
*.h5
*.joblib

# Data and generated files
data/
datasets/
.index_manifest/
*.sqlite
*.sqlite3
*.db
*.tmp
*.temp